<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <object class="GtkWindow" id="window">
    <property name="title">MP3</property>
    <property name="default-width">400</property>
    <property name="default-height">600</property>
    <child>
        <object class="GtkBox" id="main_page">

             <property name="orientation">vertical</property>
             <property name="spacing">10</property>
             <style>
                <class name="main_page"/>
             </style>
             <child>
                <object class="GtkBox" id="main_header">
                    <property name="valign">GTK_ALIGN_START</property>
                    <property name="orientation">vertical</property>
                    <style>
                        <class name="main_head"/>
                    </style>
                     <child>
                        <object class="GtkBox">
                            <property name="halign">center</property>
                            <property name="valign">center</property>
                            <style>
                                <class name="line-head"/>
                            </style>
                            <child>
                                <object class="GtkImage">
                                <property name="file">pic/player.png</property>
                                <property name="pixel-size">64</property>
                                <property name="margin-top">10</property>
                                <property name="margin-start">25</property>
                                </object>
                            </child>
                        </object>
                     </child>
                </object>

             </child>
            
            

            <child>
                <object class="GtkBox">
                    <property name="halign">center</property>
                    <property name="hexpand">False</property>
                    <property name="width-request">500</property>
                    <property name="orientation">vertical</property>
                    <child>
                        <object class="GtkScale" id="main_scale">
                            <property name="orientation">horizontal</property>
                            <property name="hexpand">True</property>
                            <property name="halign">fill</property>
                            <property name="draw-value">False</property>
                            <style>
                                <class name="scale"></class>
                            </style>
                        </object>
                    </child>
                    <child>
                        <object class="GtkLabel" id="main_label_time">
                            <property name="label">text</property>
                            <property name="halign">end</property>
                            <property name="margin-end">15</property>
                        </object>
                    </child>
                </object>
            </child>
            
           



            <child>
                <object class="GtkBox">
                    <property name="orientation">horizontal</property>
                    <property name="halign">center</property>
                    <property name="spacing">5</property>
                    
                    <child>
                        <object class="GtkButton" id="main_prev_button">
                            <property name="halign">center</property>
                            <property name="valign">center</property>
                            <child>
                                <object class="GtkImage" id="main_prev_button_icon">
                                <property name="file">pic/prev.png</property>
                                <property name="pixel-size">32</property>
                                </object>
                            </child>
                            <style>
                                <class name="last_button"/>
                            </style>
                        </object>
                    </child>
                    <child>
                        <object class="GtkButton" id="main_play_button">
                            <property name="halign">center</property>
                            <property name="valign">center</property>
                            <child>
                                <object class="GtkImage" id="main_play_button_icon">
                                <property name="file">pic/play.png</property>
                                <property name="pixel-size">32</property>
                                </object>
                            </child>
                            <style>
                                <class name="last_button"/>
                            </style>
                        </object>
                    </child>
                    <child>
                        <object class="GtkButton" id="main_next_button">
                            <property name="halign">center</property>
                            <property name="valign">center</property>
                            <child>
                                <object class="GtkImage" id="main_next_button_icon">
                                <property name="file">pic/next.png</property>
                                <property name="pixel-size">32</property>
                                </object>
                            </child>
                            <style>
                                <class name="last_button"/>
                            </style>
                        </object>
                    </child>
                </object>

            </child>
            
           

           





        </object>
    </child>
  </object>
</interface>